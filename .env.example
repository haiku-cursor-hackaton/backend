SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Produccion: https://genko-platform-production.up.railway.app
MCP_PATH=/mcp
ENVIRONMENT=development
# Origenes permitidos por CORS (separados por coma). Los localhost de desarrollo
# ya vienen por defecto; en produccion pon aqui el dominio del frontend.
# Ej: CORS_ORIGINS=https://genko-portal.netlify.app
CORS_ORIGINS=
