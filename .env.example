# Same project as VITE_SUPABASE_URL in frontend/.env
SUPABASE_URL=https://your-project.supabase.co
# Dashboard → API → service_role (secret). Never expose in frontend VITE_* vars.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Railway production: https://genko-platform-production.up.railway.app

MCP_PATH=/mcp
ENVIRONMENT=development

# Comma-separated browser origins (localhost defaults are built-in).
# Railway production (genko-portal):
# CORS_ORIGINS=https://genko-portal-production.up.railway.app
CORS_ORIGINS=
